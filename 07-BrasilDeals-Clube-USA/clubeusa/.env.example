# ============================================================
#  .env.example — Clube USA
#  NUNCA commite o .env real no git
#  Copie este arquivo para .env e preencha os valores
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_KEY=eyJxxxxx   # nunca expor no frontend

# --- Z-API WhatsApp ---
ZAPI_INSTANCE=SUA_INSTANCE
ZAPI_TOKEN=SEU_TOKEN
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN

# --- Seguranca ---
JWT_SECRET=gere_com_openssl_rand_hex_32
ENCRYPTION_KEY=gere_com_openssl_rand_hex_32
API_SECRET_KEY=gere_com_openssl_rand_hex_32

# --- Amazon Associates ---
AMAZON_ACCESS_KEY=SUA_KEY
AMAZON_SECRET_KEY=SUA_SECRET
AMAZON_PARTNER_TAG=clubeusa-20

# --- App ---
APP_URL=https://clubeusa.com
ENVIRONMENT=production   # production | development

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_xxxxx        # sk_test_xxxxx para testes
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_VIP_PRICE_ID=price_xxxxx        # ID do preco $4.99/mes no Stripe

# Admin
ADMIN_SECRET=troque-por-um-token-secreto-longo
