# OpenCage (https://opencagedata.com)
# Se não configurado, fallback para Nominatim
OPENCAGE_API_KEY=c2b569ab13d347ddbfcfa49a9544733a

# Nominatim usa OpenStreetMap - NÃO PRECISA DE CHAVE
# Sempre disponível como fallback

# ============================================================================
