# ── Banco de dados (Supabase) ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── IA e análise ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Valuação de mercado ───────────────────────────────────────────────────────
RENTCAST_API_KEY=...

# ── Alertas por email ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
ALERT_EMAIL=seu@email.com

# ── Credenciais das plataformas de leilão ─────────────────────────────────────
BID4ASSETS_EMAIL=seu@email.com
BID4ASSETS_PASSWORD=...
GOVEASE_EMAIL=seu@email.com
GOVEASE_PASSWORD=...
REALAUCTION_EMAIL=seu@email.com
REALAUCTION_PASSWORD=...

# ── Produção ──────────────────────────────────────────────────────────────────
# URL do frontend (para CORS) — preencher após deploy no Vercel
FRONTEND_URL=https://landhq.vercel.app

# Porta da API (Railway define automaticamente via $PORT)
PORT=8000

# "development" para reload automático, "production" para produção
ENVIRONMENT=production

# Desligar scheduler em caso de debug (padrão: true)
ENABLE_SCHEDULER=true
